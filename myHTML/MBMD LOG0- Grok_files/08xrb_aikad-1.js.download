`,T=`
  uniform float uTime;
  uniform vec3  uIdleColor;
  uniform vec2  uResolution;
  uniform float uBaseHeight;
  uniform float uExposure;

  varying vec2 vUv;

  const float TURB_START = 2.58;
  const float WAVE_SPEED = 0.3;
  const float TURB_SPEED = 1.0;
  const vec3  WAVE_VEC   = vec3(1.0, 4.0, 2.0);

  #define AURORA_LAYERS 4

  const mat3 gold1 = mat3(
    vec3(-0.571464913, +0.814921382, +0.096597072),
    vec3(-0.278044873, -0.303026659, +0.911518454),
    vec3(+0.772087367, +0.494042493, +0.399753815)
  );

  float hash(vec2 p) {
    vec3 p3 = fract(vec3(p.xyx) * 0.1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
  }

  float blueDither(vec2 p, float t) {
    return hash(p + fract(t * vec2(9.0, 7.0)));
  }

  vec3 turb(vec3 p, float time, float waveAmp, float turbIntensity) {
    float t = TURB_SPEED * time;
    t += waveAmp * cos(WAVE_SPEED * time - dot(p, WAVE_VEC));

    mat3 ori = mat3(1.0);
    vec3 w = vec3(0.0);

    ori = ori * gold1;
    float f1 = TURB_START;
    w += sin(ori * (w + p).zxy * f1 + t + vec3(f1, 6.0, t)) * ori / f1;

    ori = ori * gold1;
    float f2 = TURB_START + 1.0;
    w += sin(ori * (w + p).zxy * f2 + t + vec3(f2, 6.0, t)) * ori / f2;

    ori = ori * gold1;
    float f3 = TURB_START + 2.0;
    w += sin(ori * (w + p).zxy * f3 + t + vec3(f3, 6.0, t)) * ori / f3;

    return turbIntensity * w;
  }

  void main() {
    vec2 fragCoord = vUv * uResolution;
    vec2 uv = vUv;

    vec3 baseColor = uIdleColor;

    float turbIntensity = 0.28;
    float waveAmp       = 0.22;
    float auroraHeight  = uBaseHeight;
    float exposure      = uExposure;

    vec3 col = vec3(0.0);

    for (int i = 0; i < AURORA_LAYERS; i++) {
      float fi = float(i);
      float layerFrac = fi / float(AURORA_LAYERS - 1);

      vec3 p = vec3(
        uv.x * (2.5 + fi * 0.6) + fi * 3.7,
        fi * 1.9 + 0.5,
        uTime * (0.1 + fi * 0.025)
      );
      vec3 t = turb(p, uTime, waveAmp, turbIntensity);

      float warpedY = uv.y + t.x * 0.06;
      float layerH = auroraHeight * (1.0 - layerFrac * 0.4);
      float vFade = exp(-warpedY * (2.5 + fi * 0.7) / max(layerH, 0.01));

      float streak = sin(uv.x * (8.0 + fi * 6.0) + t.y * 3.0 + fi * 2.1);
      streak = 0.5 + 0.5 * streak;
      streak = pow(streak, 0.5 + layerFrac * 0.3);
      streak = mix(0.3, 1.0, streak);

      float fine = sin(uv.x * (22.0 + fi * 8.0) + t.z * 4.0 + uTime * 0.15);
      fine = 0.5 + 0.5 * fine;
      fine = mix(0.6, 1.0, fine);

      float opacity = (1.0 - layerFrac * 0.4) * 0.25;
      vec3 layerColor = mix(baseColor, mix(baseColor, vec3(1.0), 0.3), layerFrac * 0.3);
      col += vFade * streak * fine * opacity * layerColor;
    }

    float baseGlow = exp(-uv.y * 10.0);
    col += baseColor * baseGlow * 0.4;

    float wideGlow = exp(-uv.y * 3.0);
    col += baseColor * wideGlow * 0.08;

    col = 1.0 - exp(-exposure * col);

    float grain = blueDither(fragCoord, uTime);
    col += (grain - 0.5) * 0.025;

