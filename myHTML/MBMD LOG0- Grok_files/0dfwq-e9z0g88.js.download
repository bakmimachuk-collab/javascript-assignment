            .html2pdf__overlay,
            .html2pdf__overlay *,
            .grok_report,
            .grok_report * {
              color: black !important;
              background-color: transparent !important;
              border-color: black !important;
              outline-color: black !important;
              text-decoration-color: black !important;
              -webkit-text-stroke-color: black !important;
              column-rule-color: black !important;
              caret-color: auto !important;
              accent-color: auto !important;
              fill: currentColor !important;
              stroke: none !important;
              box-shadow: none !important;
              text-shadow: none !important;
              letter-spacing: normal !important;
              word-spacing: normal !important;
              font-variant-ligatures: normal !important;
              font-feature-settings: normal !important;
            }

            .grok_report,
            .html2pdf__container {
              background-color: white !important;
            }

            /* 
               Turn off native bullets/numbers. Create custom ones. 
               Otherwise, the PDF will have bullets/numbers (likely
               because of ::marker in the original HTML).
            */
            .grok_report ol, .grok_report ul {
              list-style: none !important;
              padding-inline-start: 0;
              margin: 0;
            }

            /* Reserve space for marker column + gap (override prose utilities) */
            .grok_report li {
              position: relative;
              display: block;
              padding-inline-start: calc(var(--list-width, 3) * 1ch) !important;
            }

            /* Marker column: fixed width, anchored to start edge */
            .grok_report ol > li::before,
            .grok_report ul > li::before {
              position: absolute;
              inset-inline-start: 0;
              inset-block-start: 0;
              text-align: left;
              white-space: nowrap;
            }

            .grok_report ol { counter-reset: g_ol !important; }
            .grok_report ol > li { counter-increment: g_ol !important; }
            .grok_report ol > li::before {
              content: counter(g_ol) ".";
              inline-size: calc(var(--list-width, 3) * 1ch);
            }

            .grok_report ul > li::before {
              content: "•";
              inline-size: calc(var(--list-width, 1) * 1ch);
              display: inline-block;
            }

            /* Target both explicit and computed RTL */
            .grok_report [dir="rtl"] ol > li::before,
            .grok_report [dir="rtl"] ul > li::before,
            .grok_report :dir(rtl) ol > li::before,
            .grok_report :dir(rtl) ul > li::before {
              text-align: right;
            }

            /* Code blocks should wrap text */
            .grok_report pre,
            .grok_report code {
              white-space: pre-wrap !important;
              word-wrap: break-word !important;
              overflow-wrap: break-word !important;
            }

            /* Fix KaTeX fraction line positioning for PDF export */
            .grok_report .katex .frac-line {
              transform: translateY(0.5em);
            }

            /* Ensure images are visible and properly sized in the PDF */
            .grok_report img {
              max-width: 100% !important;
              height: auto !important;
              opacity: 1 !important;
              display: block !important;
              object-fit: contain !important;
              break-inside: avoid;
            }

            .grok_report pre,
            .grok_report blockquote,
            .grok_report table,
            .grok_report tr,
            .grok_report li,
            .grok_report h1, .grok_report h2, .grok_report h3,
            .grok_report h4, .grok_report h5, .grok_report h6 {
              break-inside: avoid;
            }
